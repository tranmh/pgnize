# ---- Database ----
DATABASE_URL=postgres://pgnize:pgnize@localhost:5432/pgnize?sslmode=disable
POSTGRES_USER=pgnize
POSTGRES_PASSWORD=pgnize
POSTGRES_DB=pgnize

# ---- Auth ----
# 32+ byte random secret used to sign/derive session tokens.
AUTH_SECRET=change-me-in-production-please-32-bytes-min

# ---- HTTP ----
API_ADDR=:8080
PUBLIC_BASE_URL=http://localhost:8080

# ---- Storage (raw score-sheet images) ----
# auto picks S3 when S3_BUCKET is set, else filesystem under STORAGE_DIR.
STORAGE_DRIVER=auto
STORAGE_DIR=./data/uploads
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=pgnize-uploads
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ---- Recognition ----
# fake = deterministic recognizer (tests/CI); ollama = local VLM via Ollama HTTP;
# gemini = Google Gemini Flash (cloud, set GEMINI_API_KEY below).
# The backend is also selectable per upload/convert request; this is the default.
RECOGNIZER=fake
RECOGNIZER_MODEL=minicpm-v
OLLAMA_HOST=http://localhost:11434
# Gemini Flash (Google AI Studio). When GEMINI_API_KEY is set the gemini backend is
# offered to clients and becomes the default recognizer.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_HOST=https://generativelanguage.googleapis.com
# Gemini 2.5 "thinks" by default and bills those tokens against the output budget,
# which can truncate the JSON after a single move on a full sheet. 0 disables thinking
# (the default; right for transcription); -1 lets the model decide dynamically.
GEMINI_THINKING_BUDGET=0
RECOGNITION_WORKERS=2
FEWSHOT_MAX_EXAMPLES=3

# ---- Limits / retention ----
UPLOAD_MAX_BYTES=15728640
ANON_UPLOAD_TTL_DAYS=7

# Set to true to disable ALL per-IP/per-user rate limiting. Local automated
# testing only — never enable this in production.
RATE_LIMIT_DISABLED=false
