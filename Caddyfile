# Inner reverse proxy: /api/* -> Go backend, everything else -> Next.js.
#
# TLS and the public hostname (pgnize.openpairing.org) are handled by the shared
# EDGE Caddy in the swiss-manager stack, which proxies here over the 'edge'
# docker network. This block therefore serves plain HTTP on :80 and only does
# path routing — it must NOT provision its own certificate.
:80 {
	encode gzip

	handle /api/* {
		reverse_proxy api:8080
	}
	handle /healthz {
		reverse_proxy api:8080
	}
	handle {
		reverse_proxy web:3000
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
}
